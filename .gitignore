# Build
build/
# …but keep the source-of-truth app icons. Wails reads these directly
# from build/ at packaging time; if they're not committed the dock icon
# silently reverts to the default lettermark on every fresh clone.
# Three-step negation because git won't re-include a file under an
# ignored directory unless the directory itself is also re-included
# and the wildcard-ignore is re-applied to everything else inside it.
!kube/backend/build/
kube/backend/build/*
!kube/backend/build/appicon.png
!kube/mcp/build/
kube/mcp/build/*
!kube/mcp/build/appicon.png
**/view/dist/
HomePage/dist/
**/node_modules/

# Terraform
**/*.tfstate
**/*.tfstate.backup


# IDE
.idea/
.vscode/
*.swp

# Python
**/__pycache__/
*.egg-info/

# OS
.DS_Store
Thumbs.db

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib

# Wails
kube/view/src/wailsjs/

# Terraform local state + provider downloads. The provider binaries are
# multi-hundred-MB and trip GitHub's 100MB-per-file ceiling.
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
.terraform.lock.hcl

# Dagster runtime data (anomstack)
**/dagster_home/

# Design references (static mocks, not source)
design-references/*.html

# Env
.env
.env.local
