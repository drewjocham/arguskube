# Go API
PORT=8080
DATABASE_URL=postgres://api-gov:api-gov@localhost:5432/api-gov?sslmode=disable
AGENT_SERVICE_URL=http://localhost:8001

# LLM — DeepSeek direct API (cheaper than SiliconFlow)
DEEPSEEK_API_KEY=sk-your-key-here
AGENT_LLM_MODEL=deepseek-chat

# Python Agents
AGENT_DATABASE_URL=postgresql+psycopg://api-gov:api-gov@localhost:5432/api-gov
AGENT_REDIS_URL=redis://localhost:6379/0
AGENT_DRIFT_THRESHOLD=0.85
LLM_BATCH_SIZE=50
LLM_BATCH_WINDOW_SEC=300

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
