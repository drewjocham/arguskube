# Go API
PORT=8080
DATABASE_URL=postgres://api-gov:api-gov@localhost:5432/api-gov?sslmode=disable
AGENT_SERVICE_URL=http://localhost:8001

# SiliconFlow
SILICONFLOW_API_KEY=sk-your-key-here
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-ai/DeepSeek-V3-0324

# Python Agents
AGENT_SILICONFLOW_API_KEY=sk-your-key-here
AGENT_LLM_MODEL=deepseek-ai/DeepSeek-V3-0324
AGENT_EMBEDDING_MODEL=BAAI/bge-m3
AGENT_DRIFT_THRESHOLD=0.85
AGENT_DATABASE_URL=postgresql+psycopg://api-gov:api-gov@localhost:5432/api-gov
AGENT_REDIS_URL=redis://localhost:6379/0

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
