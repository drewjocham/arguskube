{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "kubewatcher",
  "outputfilename": "kubewatcher",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "frontend:dir": "../view",
  "wailsjsdir": "../view/src",
  "skipSelfSign": true,
  "author": {
    "name": "djocham",
    "email": "me@djocham.com"
  },
  "postBuildHooks": {
    "darwin/arm64": "xattr -cr build/bin/kubewatcher.app && codesign --force --deep --sign - build/bin/kubewatcher.app",
    "darwin/amd64": "xattr -cr build/bin/kubewatcher.app && codesign --force --deep --sign - build/bin/kubewatcher.app",
    "darwin/universal": "xattr -cr build/bin/kubewatcher.app && codesign --force --deep --sign - build/bin/kubewatcher.app"
  },
  "info": {
    "companyName": "djocham",
    "productName": "KubeWatcher",
    "copyright": "Copyright 2024 djocham"
  }
}