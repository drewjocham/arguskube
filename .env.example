# ─── Argus Docker Compose Environment ───

# Kubernetes — mount a kubeconfig file or set in-cluster mode.
# KUBEWATCHER_KUBECONFIG=/root/.kube/config
# KUBEWATCHER_CONTEXT=
# KUBEWATCHER_NAMESPACE=
# KUBEWATCHER_IN_CLUSTER=false

# AI / LLM — use Ollama (included) or an external DeepSeek API key.
# When using Ollama, set the base URL; the compose stack handles the rest.
# DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# Anomaly detection (optional). Choose one backend:
#   anomstack — lightweight local Python service (single-user)
#   flink     — Apache Flink cluster on VM (multi-user / enterprise)
# Set the URL for your chosen backend; the other can be left empty.
# ANOMSTACK_URL=http://localhost:8087
# ANOMSTACK_API_KEY=
# KUBEWATCHER_FLINK_URL=http://<flink-vm-ip>:8087
# KUBEWATCHER_FLINK_API_KEY=

# Prometheus — auto-configured by the compose stack.
PROMETHEUS_URL=http://prometheus:9090

# Argo CD integration (optional).
# ARGOCD_URL=https://argocd.example.com
# ARGOCD_TOKEN=
# ARGOCD_INSECURE=false

# Feature tier.
KUBEWATCHER_TIER=pro

# Logging.
KUBEWATCHER_LOG_LEVEL=info
KUBEWATCHER_LOG_FORMAT=json

# Server.
KUBEWATCHER_PORT=8080

# Grafana admin password.
GF_SECURITY_ADMIN_PASSWORD=argus

# ── Vector Alert Ingress ───────────────────────────────────────────
# The alert-ingress is now a Vector pipeline (replaces the old Go service).
# It receives Anomstack webhooks on :8080 and routes to configured sinks.
# By default it writes structured JSON to stdout (captured by container logs).
#
# Enable S3 archival:
# S3_ALERTS_BUCKET=argus-alerts
# AWS_REGION=us-west-2
#
# Enable GCP PubSub:
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# PUBSUB_TOPIC=argus-alerts

# -----------------------------------------------------------------------------
# Authentication. Argus requires every user to sign in — there is no
# "no auth" mode. The desktop app starts on a login screen; users can
# either register a local account or sign in via Google / corporate SSO.
# -----------------------------------------------------------------------------

# Public origin where OAuth providers will redirect back to. For the
# desktop app this can stay as 127.0.0.1; for SaaS, set to your public
# https URL (e.g. https://argus.acme.com).
# KUBEWATCHER_AUTH_BASE_URL=http://127.0.0.1:8080

# Allow self-registration via the LoginView signup tab. Flip to "false"
# in SaaS deployments where account creation is invite-only.
# KUBEWATCHER_AUTH_ALLOW_SIGNUP=true

# Google OAuth — create a Web Application credential at
# https://console.cloud.google.com/apis/credentials and add
# {KUBEWATCHER_AUTH_BASE_URL}/auth/google/callback to the Authorized
# redirect URIs.
# KUBEWATCHER_GOOGLE_CLIENT_ID=
# KUBEWATCHER_GOOGLE_CLIENT_SECRET=

# Generic corporate OIDC — Okta, Azure AD, Auth0, Keycloak, Google
# Workspace Identity, etc. The issuer's discovery doc must be reachable
# from the server. Add {KUBEWATCHER_AUTH_BASE_URL}/auth/oidc/callback
# to the provider's allowed redirect URIs.
# KUBEWATCHER_OIDC_ISSUER=https://acme.okta.com
# KUBEWATCHER_OIDC_CLIENT_ID=
# KUBEWATCHER_OIDC_CLIENT_SECRET=
# KUBEWATCHER_OIDC_DISPLAY_NAME=Acme SSO

# Optional service-account token for CI / automation. When set, callers
# can hit /api/* with `Authorization: Bearer <token>` instead of going
# through the user-account flow. Leave unset for the desktop app —
# session auth is the only path users need.
# KUBEWATCHER_API_TOKEN=

# Local-development escape hatch. When "true" AND the API is bound to
# loopback, every /api request is treated as authenticated and the
# frontend skips the LoginView. Refuses to take effect when the API is
# bound to anything else, so a leftover env var can't ship a public
# build with auth off. NEVER set this in staging or production.
# KUBEWATCHER_AUTH_DISABLED=false
