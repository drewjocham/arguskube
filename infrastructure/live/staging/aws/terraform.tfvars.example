# Copy to terraform.tfvars (gitignored) and fill in. Or pass via the
# CLI: `terraform apply -var deepseek_api_key=$DEEPSEEK_API_KEY ...`.
# CI pipelines typically inject these via TF_VAR_<name> env vars.

aws_region             = "us-west-2"
image_tag              = ""
deepseek_api_key       = ""
argocd_url             = ""
argocd_token           = ""
anomstack_url          = ""
grafana_admin_password = ""
