# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

project_id  = "my-gcp-project"
region      = "us-central1"
zone        = "us-central1-a"

# Generate with: openssl rand -hex 32
llm_api_key = "REPLACE_ME"

# Optional — uncomment for gated HuggingFace models.
# hf_token  = "hf_..."

# Restrict who can reach the endpoint. Use your office CIDR or a VPN.
allowed_source_ranges = [
  # "203.0.113.0/24",
]

# Cheaper L4 default; uncomment for more GPU.
# machine_type = "a2-highgpu-1g"   # 1x A100-40GB
# gpu_type     = "nvidia-tesla-a100"
# gpu_count    = 1
