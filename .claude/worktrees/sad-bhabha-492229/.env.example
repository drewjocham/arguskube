# ─── KubeWatcher Docker Compose Environment ───

# Kubernetes — mount a kubeconfig file or set in-cluster mode.
# KUBEWATCHER_KUBECONFIG=/root/.kube/config
# KUBEWATCHER_CONTEXT=
# KUBEWATCHER_NAMESPACE=
# KUBEWATCHER_IN_CLUSTER=false

# AI / LLM — use Ollama (included) or an external DeepSeek API key.
# When using Ollama, set the base URL; the compose stack handles the rest.
# DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# Anomaly detection (optional).
# ANOMSTACK_URL=http://localhost:8087
# ANOMSTACK_API_KEY=

# Prometheus — auto-configured by the compose stack.
PROMETHEUS_URL=http://prometheus:9090

# Argo CD integration (optional).
# ARGOCD_URL=https://argocd.example.com
# ARGOCD_TOKEN=
# ARGOCD_INSECURE=false

# Feature tier.
KUBEWATCHER_TIER=pro

# Logging.
KUBEWATCHER_LOG_LEVEL=info
KUBEWATCHER_LOG_FORMAT=json

# Server.
KUBEWATCHER_PORT=8080

# Grafana admin password.
GF_SECURITY_ADMIN_PASSWORD=kubewatcher
