# alert-ingress configuration
#
# Mode: "stdout" (dev, logs alerts to stdout) or "gcp" (production, publishes to PubSub)
ALERT_INGRESS_MODE=stdout

# HTTP port (default: 8080)
ALERT_INGRESS_PORT=8080

# Google Cloud PubSub (only needed in gcp mode)
GOOGLE_CLOUD_PROJECT=your-gcp-project
PUBSUB_TOPIC=argus-alerts
